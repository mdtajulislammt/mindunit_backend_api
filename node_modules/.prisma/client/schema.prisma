datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// User Model
model User {
  id               String   @id @default(uuid())
  firstName        String
  lastName         String
  email            String   @unique
  passwordHash     String
  headline         String   @default("Brain Health Enthusiast | MindUnite Member")
  avatarUrl        String?
  connectionsCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  posts        Post[]
  comments     Comment[]
  replies      Reply[]
  postLikes    PostLike[]
  commentLikes CommentLike[]
  replyLikes   ReplyLike[]
  groupMembers GroupMember[]
}

// Post Model
model Post {
  id        String   @id @default(uuid())
  content   String   @db.Text
  imageUrl  String?
  privacy   Privacy  @default(PUBLIC)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Author
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Relations
  likes    PostLike[]
  comments Comment[]
}

enum Privacy {
  PUBLIC
  PRIVATE
}

// Post Likes
model PostLike {
  id        String   @id @default(uuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId]) // Prevents duplicate likes
}

// Comment Model
model Comment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Relations
  likes   CommentLike[]
  replies Reply[]
}

// Comment Likes
model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([commentId, userId])
}

// Nested Reply Model
model Reply {
  id        String   @id @default(uuid())
  content   String   @db.Text
  createdAt DateTime @default(now())

  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  authorId  String
  author    User    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Relations
  likes ReplyLike[]
}

// Reply Likes
model ReplyLike {
  id        String   @id @default(uuid())
  replyId   String
  reply     Reply    @relation(fields: [replyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([replyId, userId])
}

// Group Model
model Group {
  id           String   @id @default(uuid())
  name         String
  category     String
  avatarUrl    String
  membersCount Int      @default(0)
  createdAt    DateTime @default(now())

  // Relations
  members GroupMember[]
}

// Group Membership
model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt DateTime @default(now())

  @@unique([groupId, userId])
}
